# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Required: Database - NeonDB
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Required: Auth - Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional bootstrap: creates the first owner invite during bun run db:seed
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_NAME=Dekoria Owner

# Optional Auth - Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional MVP service: ImageKit uploads and media previews
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_URL_ENDPOINT=

# Optional MVP service: AI morning summary generation
GOOGLE_GENERATIVE_AI_API_KEY=

# Mastra
MASTRA_TELEMETRY_DISABLED=false

# Optional internal app security
INTERNAL_API_SECRET=
